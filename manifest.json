{
  "manifest_version": 3,
  "name": "微信读书辅助增强版",
  "version": "0.2.0",
  "description": "专为微信读书网页版（weread.qq.com）打造的纯净阅读辅助插件：自定义屏占比、工具栏浮动悬停。零依赖、不收集任何用户数据。",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://weread.qq.com/*"
      ],
      "css": [
        "content.css"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_end"
    }
  ]
}
