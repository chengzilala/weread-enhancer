{
  "manifest_version": 3,
  "name": "微信读书屏占比调节器",
  "version": "0.4.0",
  "description": "自定义微信读书网页版阅读区域宽度，50%-100%自由调节，设置自动保存。",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://weread.qq.com/*"
      ],
      "css": [
        "content.css"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_end"
    }
  ]
}
